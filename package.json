{
  "name": "@requence/tokenized-search",
  "version": "1.10.0",
  "description": "Tokenized search input with TipTap-powered rich text editing, dropdown suggestions, and structured query parsing for React",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "bun": "./src/core.ts",
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "NODE_ENV=production bun run build.ts",
    "check-types": "tsc --noEmit",
    "cs": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish",
    "prepublishOnly": "bun run build",
    "dev:docs": "cd docs && bun run dev"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-document": "^3.22.3",
    "@tiptap/extension-history": "^3.22.3",
    "@tiptap/extension-paragraph": "^3.22.3",
    "@tiptap/extension-text": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.1"
  },
  "peerDependenciesMeta": {
    "@tiptap/core": {
      "optional": true
    },
    "@tiptap/extension-document": {
      "optional": true
    },
    "@tiptap/extension-history": {
      "optional": true
    },
    "@tiptap/extension-paragraph": {
      "optional": true
    },
    "@tiptap/extension-text": {
      "optional": true
    },
    "@tiptap/pm": {
      "optional": true
    },
    "@tiptap/react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "tailwind-merge": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-document": "^3.22.3",
    "@tiptap/extension-history": "^3.22.3",
    "@tiptap/extension-paragraph": "^3.22.3",
    "@tiptap/extension-text": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "license": "MIT",
  "homepage": "https://tokenized-search.docs.requence.cloud/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/requence/tokenized-search.git"
  },
  "bugs": {
    "url": "https://github.com/requence/tokenized-search/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
